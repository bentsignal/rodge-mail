{
  "name": "@rodge-mail/icloud-bridge",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/main.ts --format esm --out-dir dist --sourcemap",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsx watch src/main.ts",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "start": "node dist/main.js",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rodge-mail/convex": "workspace:*",
    "imapflow": "^1.4.6",
    "mailparser": "^3.9.14",
    "nodemailer": "^9.0.3",
    "postgres": "^3.4.9",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@rodge-mail/eslint-config": "workspace:*",
    "@rodge-mail/prettier-config": "workspace:*",
    "@rodge-mail/tsconfig": "workspace:*",
    "@types/mailparser": "^3.4.6",
    "@types/node": "catalog:",
    "@types/nodemailer": "^8.0.1",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "catalog:"
  },
  "prettier": "@rodge-mail/prettier-config"
}
