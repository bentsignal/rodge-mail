{
  "name": "@rodge-mail/web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env vite build",
    "clean": "git clean -xdf .cache dist .turbo node_modules",
    "dev": "pnpm with-env portless \"$(../../scripts/portless-app-name.sh www.rodge-mail)\" --lan vite dev",
    "dev:app": "pnpm with-env vite dev",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "start": "pnpm with-env vite preview",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@better-auth/passkey": "1.6.11",
    "@better-auth/utils": "0.4.0",
    "@convex-dev/better-auth": "catalog:",
    "@convex-dev/react-query": "^0.1.0",
    "@fontsource-variable/geist": "^5.2.7",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@rodge-mail/config": "workspace:*",
    "@rodge-mail/convex": "workspace:*",
    "@rodge-mail/features": "workspace:*",
    "@rodge-mail/std": "workspace:*",
    "@rodge-mail/ui-web": "workspace:*",
    "@t3-oss/env-core": "^0.13.8",
    "@tanstack/devtools-vite": "^0.5.0",
    "@tanstack/react-devtools": "^0.9.4",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "@tanstack/react-router-ssr-query": "catalog:",
    "@tanstack/react-start": "catalog:",
    "better-auth": "catalog:",
    "convex": "catalog:",
    "great-time": "^1.0.0",
    "lucide-react": "catalog:",
    "next-themes": "^0.4.6",
    "nitro": "3.0.1-alpha.2",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "rostra": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@rodge-mail/eslint-config": "workspace:*",
    "@rodge-mail/prettier-config": "workspace:*",
    "@rodge-mail/tailwind-config": "workspace:*",
    "@rodge-mail/tsconfig": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "catalog:",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv-cli": "^10.0.0",
    "eslint": "catalog:",
    "portless": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "prettier": "@rodge-mail/prettier-config",
  "portless": {
    "name": "www.rodge-mail",
    "script": "dev:app"
  }
}
