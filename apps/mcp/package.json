{
  "name": "@rodge-mail/mcp",
  "version": "0.1.0",
  "description": "Read-only local MCP adapter for Rodge Mail.",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "start": "node --experimental-strip-types src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@rodge-mail/agent-contract": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@rodge-mail/eslint-config": "workspace:*",
    "@rodge-mail/prettier-config": "workspace:*",
    "@rodge-mail/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.0.17"
  },
  "prettier": "@rodge-mail/prettier-config"
}
