{
  "name": "rodge-mail",
  "description": "A focused, AI-native email client for web, desktop, and mobile.",
  "private": true,
  "engines": {
    "node": ">=22.12.0",
    "pnpm": "^9.15.4"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "@better-auth/utils": "0.4.0",
      "@better-fetch/fetch": "1.1.21",
      "lightningcss": "1.30.1",
      "react": "19.2.3",
      "react-dom": "19.2.3"
    },
    "patchedDependencies": {
      "@better-auth/passkey@1.6.11": "patches/@better-auth__passkey@1.6.11.patch",
      "expo-modules-jsi@56.0.8": "patches/expo-modules-jsi@56.0.8.patch",
      "expo-better-auth-passkey@1.4.3": "patches/expo-better-auth-passkey@1.4.3.patch"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules .turbo",
    "clean:all": "turbo run clean",
    "dev": "portless proxy start --lan && turbo run dev --parallel --continue",
    "dev:web": "portless proxy start --lan && turbo run dev --parallel --continue -F @rodge-mail/web...",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:ws": "pnpm dlx sherif@latest",
    "postinstall": "pnpm lint:ws",
    "readiness": "node scripts/check-production-readiness.mjs",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "create-package": "turbo gen init",
    "android": "pnpm --filter @rodge-mail/mobile android",
    "ios": "pnpm --filter @rodge-mail/mobile ios"
  },
  "devDependencies": {
    "@rodge-mail/prettier-config": "workspace:*",
    "@turbo/gen": "^2.5.8",
    "portless": "catalog:",
    "prettier": "catalog:",
    "turbo": "^2.5.8",
    "typescript": "catalog:"
  },
  "prettier": "@rodge-mail/prettier-config"
}
