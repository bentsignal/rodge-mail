{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".cache/tsbuildinfo.json", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^topo", "^dev"],
      "cache": false,
      "persistent": false
    },
    "format": {
      "outputs": [".cache/.prettiercache"],
      "outputLogs": "new-only"
    },
    "lint": {
      "dependsOn": ["^topo"],
      "outputs": [".cache/.eslintcache"]
    },
    "test": {
      "dependsOn": ["^topo"]
    },
    "typecheck": {
      "dependsOn": ["^topo"],
      "outputs": [".cache/tsbuildinfo.json"]
    },
    "clean": {
      "cache": false
    },
    "//#clean": {
      "cache": false
    },
    "push": {
      "cache": false,
      "interactive": true
    },
    "studio": {
      "cache": false,
      "persistent": true
    }
  },
  "globalEnv": [
    "BETTER_AUTH_SECRET",
    "CONVEX_DEPLOY_KEY",
    "VITE_NODE_ENV",
    "OPENAI_API_KEY",
    "AI_CLASSIFICATION_MODEL",
    "AI_EMBEDDING_MODEL",
    "ANDROID_PASSKEY_ORIGINS"
  ],
  "globalPassThroughEnv": [
    "NODE_ENV",
    "CI",
    "npm_lifecycle_event",
    "PORT",
    "HOST",
    "PORTLESS_URL",
    "NODE_EXTRA_CA_CERTS",
    "CONVEX_CLOUD_URL",
    "DEV",
    "MODE"
  ]
}
